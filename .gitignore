# ======================
# 【核心】解决你当前问题：忽略虚拟环境
# ======================
# 你项目里的 .venv/ 目录，下面这行必须写！
.venv/
# 其他常见虚拟环境目录（写上防患于未然）
venv/
env/
ENV/

# ======================
# Python 项目通用忽略规则
# ======================
# Python 字节码缓存（就是 __pycache__ 文件夹和 .pyc 文件）
__pycache__/
*.pyc
*.pyo
*.pyd

# 打包/构建生成的文件（pip install 时不会自动生成，但项目打包会有）
*.egg-info/
dist/
build/
*.whl

# Jupyter Notebook 相关缓存（如果你用 Jupyter 会生成）
.ipynb_checkpoints/

# ======================
# VS Code 编辑器相关文件
# ======================
.vscode/
*.code-workspace
# 如果你不想忽略 VS Code 的配置文件，可以删掉这几行

# ======================
# ======================
*.log
*.csv
*.jsonl
*.parquet
*.db
*.sqlite3